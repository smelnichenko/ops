profile: production
exclude_paths:
  - venv/
  - .cache/
  - vars/sealed-secrets-key-backup.yaml
kinds:
  - playbook: "playbooks/*.yml"
  - playbook: "deploy.yml"
  - playbook: "uninstall.yml"
  - vars: "vars/*.yml"
  - tasks: "roles/*/tasks/*.yml"
  - handlers: "roles/*/handlers/*.yml"
  - meta: "roles/*/meta/*.yml"
