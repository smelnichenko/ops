profile: production
exclude_paths:
  - venv/
  - .cache/
  - vars/sealed-secrets-key-backup.yaml
skip_list:
  # run-once[task] only matters when a play runs under strategy: free.
  # Every play in this repo uses strategy: linear (the default), and
  # the run_once tasks all carry an explicit delegate_to. Suppressing
  # globally is cleaner than scattering # noqa: run-once[task] across
  # every callsite.
  - run-once[task]
kinds:
  - playbook: "playbooks/*.yml"
  - playbook: "deploy.yml"
  - playbook: "uninstall.yml"
  - vars: "vars/*.yml"
  - tasks: "roles/*/tasks/*.yml"
  - handlers: "roles/*/handlers/*.yml"
  - meta: "roles/*/meta/*.yml"
