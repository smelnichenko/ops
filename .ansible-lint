profile: production
exclude_paths:
  - .ansible/                # ansible-compat scratch dir created at repo root
  - deploy/ansible/.ansible/ # …and another one wherever lint is invoked from
  - deploy/ansible/venv/
  - deploy/ansible/.cache/
  - deploy/ansible/vars/sealed-secrets-key-backup.yaml
skip_list:
  # run-once[task] only matters when a play runs under strategy: free.
  # Every play in this repo uses strategy: linear (the default), and
  # the run_once tasks all carry an explicit delegate_to. Suppressing
  # globally is cleaner than scattering # noqa: run-once[task] across
  # every callsite.
  - run-once[task]
kinds:
  - playbook: "deploy/ansible/playbooks/*.yml"
  - playbook: "deploy/ansible/deploy.yml"
  - playbook: "deploy/ansible/uninstall.yml"
  - vars: "deploy/ansible/vars/*.yml"
  - tasks: "deploy/ansible/roles/*/tasks/*.yml"
  - handlers: "deploy/ansible/roles/*/handlers/*.yml"
  - meta: "deploy/ansible/roles/*/meta/*.yml"
